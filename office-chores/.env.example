# ── Database & Cache ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/office_chores"
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate RS256 key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Generate with: openssl rand -hex 64
REFRESH_TOKEN_SECRET="your-64-byte-hex-secret"

# ── Google OAuth & Calendar ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
# Generate with: openssl rand -hex 32
GOOGLE_TOKEN_ENCRYPTION_KEY="your-32-byte-hex-key"

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@yourcompany.com"
SENDGRID_ASSIGNED_TEMPLATE_ID="d-your-assigned-template-id"
SENDGRID_REMINDER_TEMPLATE_ID="d-your-reminder-template-id"
SENDGRID_INVITE_TEMPLATE_ID="d-your-invite-template-id"

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
PORT=3000
NODE_ENV="development"
